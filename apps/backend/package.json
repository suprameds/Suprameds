{
  "name": "backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "db:migrate": "medusa db:migrate",
    "db:seed": "medusa exec ./src/scripts/run-migrations.ts",
    "db:setup": "medusa db:migrate && medusa exec ./src/scripts/run-migrations.ts",
    "db:setup:prod": "medusa db:migrate && SKIP_PRODUCT_SEED=true medusa exec ./src/scripts/run-migrations.ts",
    "import:products": "medusa exec ./src/scripts/import-products.ts",
    "start": "node ./src/scripts/cloud-start.mjs",
    "dev": "medusa develop",
    "dev:tee": "medusa develop 2>&1 | tee -a ../backend.log",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "email:dev": "email-preview --dir ./src/email-templates --port 9004 --hostname 0.0.0.0"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.13.4",
    "@medusajs/admin-shared": "2.13.4",
    "@medusajs/cli": "2.13.4",
    "@medusajs/dashboard": "2.13.4",
    "@medusajs/draft-order": "2.13.4",
    "@medusajs/email-preview-server": "^0.0.9",
    "@medusajs/framework": "2.13.4",
    "@medusajs/icons": "^2.13.4",
    "@medusajs/js-sdk": "2.13.4",
    "@medusajs/medusa": "2.13.4",
    "@medusajs/types": "2.13.4",
    "@medusajs/ui": "4.1.0",
    "@react-email/components": "^1.0.9",
    "@react-email/render": "^2.0.4",
    "@tanstack/react-query": "5.64.2",
    "date-fns": "^4.1.0",
    "firebase-admin": "^13.7.0",
    "medusa-plugin-razorpay-v2": "^0.1.4",
    "pdfkit": "^0.18.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.4",
    "@swc/core": "1.5.7",
    "@swc/jest": "^0.2.36",
    "@types/jest": "29.5.13",
    "@types/node": "20.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "jest": "29.7.0",
    "prop-types": "15.8.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-router-dom": "^6.30.3",
    "ts-node": "10.9.2",
    "typescript": "5.8.3",
    "vite": "5.2.11",
    "yalc": "1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
