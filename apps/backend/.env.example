# ---- Database ----
DATABASE_URL=postgresql://user:password@host:5432/medusa
POSTGRES_URL=postgresql://user:password@host:5432/medusa

# ---- Redis (optional for local dev — Medusa falls back to in-memory event bus) ----
# Only uncomment when Redis is actually running (e.g. via Docker: docker compose up -d)
# REDIS_URL=redis://localhost:6379

# ---- CORS (comma-separated origins) ----
STORE_CORS=http://localhost:5173,http://localhost:5176
ADMIN_CORS=http://localhost:5173,http://localhost:5176,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:5176,http://localhost:9000

# ---- Auth ----
JWT_SECRET=your-jwt-secret
COOKIE_SECRET=your-cookie-secret

# ---- Razorpay (Primary payment gateway for India) ----
# Test keys: Use rzp_test_* for development; Live keys: rzp_live_* for production
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_TEST_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Optional: Merchant/account ID from Razorpay Dashboard
RAZORPAY_ACCOUNT=
# Required for webhook signature verification (from Razorpay Dashboard → Webhooks → Secret)
RAZORPAY_WEBHOOK_SECRET=

# ---- PHI Encryption (AES-256-GCM) ----
# 64-char hex key (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When set, patient names, addresses, doctor details are encrypted at rest in the database.
PHI_ENCRYPTION_KEY=

# ---- File storage (S3 / Cloudflare R2) ----
# For Cloudflare R2:
# R2_FILE_URL=https://your-bucket.r2.cloudflarestorage.com
# R2_BUCKET=your-bucket
# R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_PREFIX=
# For AWS S3:
# S3_FILE_URL=https://your-bucket.s3.amazonaws.com
# S3_BUCKET=your-bucket
# S3_REGION=ap-south-1
# S3_ENDPOINT=
# S3_PREFIX=

# ---- AfterShip (Shipment tracking) ----
AFTERSHIP_API_KEY=asat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret for signature verification (set in AfterShip Dashboard → Notifications → Webhooks)
AFTERSHIP_WEBHOOK_SECRET=

# ---- Inventory Monitoring ----
LOW_STOCK_THRESHOLD=50

# ---- Pharmacy / GST Invoice ----
WAREHOUSE_STATE=Telangana
PHARMACY_NAME=Suprameds Pharmacy
PHARMACY_GSTIN=36XXXXXXXXXXXZX
PHARMACY_ADDRESS=Hyderabad, Telangana, India
PHARMACY_DL_NUMBER=TG/28/20B/XXXXX

# ---- MSG91 (SMS OTP — DLT registered) ----
MSG91_AUTH_KEY=your-msg91-authkey
MSG91_TEMPLATE_ID_OTP=your-dlt-template-id
# Optional: token for webhook URL verification (append ?token=VALUE to webhook URL in MSG91 dashboard)
MSG91_WEBHOOK_TOKEN=

# ---- Firebase Admin (FCM push sending) ----
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Keep escaped \n in one line; paste entire PEM key from service-account JSON
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ---- Resend (Transactional emails) ----
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Suprameds <support@supracynpharma.com>

# ---- WhatsApp Business API (Meta Cloud API) ----
# Get these from Meta Business Manager → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
# Arbitrary string you choose — must match the value you enter in Meta webhook config
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
# App secret from Meta Business Manager — used to verify X-Hub-Signature-256 on incoming webhooks
WHATSAPP_APP_SECRET=

# ---- Sentry (Error monitoring) ----
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://your_sentry_dsn_here
# Optional: for source map uploads during CI/CD builds
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=suprameds-backend
