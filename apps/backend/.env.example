# ---- Database ----
DATABASE_URL=postgresql://user:password@host:5432/medusa
POSTGRES_URL=postgresql://user:password@host:5432/medusa

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- CORS (comma-separated origins) ----
STORE_CORS=http://localhost:5173,http://localhost:5176
ADMIN_CORS=http://localhost:5173,http://localhost:5176,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:5176,http://localhost:9000

# ---- Auth ----
JWT_SECRET=your-jwt-secret
COOKIE_SECRET=your-cookie-secret

# ---- Razorpay (Primary payment gateway for India) ----
# Test keys: Use rzp_test_* for development; Live keys: rzp_live_* for production
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_TEST_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Optional: Merchant/account ID from Razorpay Dashboard
RAZORPAY_ACCOUNT=
# Required for webhook signature verification (from Razorpay Dashboard → Webhooks → Secret)
RAZORPAY_WEBHOOK_SECRET=

# ---- File storage (optional) ----
# S3_FILE_URL=
# S3_BUCKET=
# S3_REGION=

# ---- Firebase Admin (FCM push sending) ----
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Keep escaped \n in one line; paste entire PEM key from service-account JSON
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
