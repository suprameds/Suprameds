<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 11 and below (API <= 30) backup rules.
  allowBackup is already false in AndroidManifest, but these exclude rules provide
  defense-in-depth in case backup ever gets enabled.
-->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="file" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="external" />
</full-backup-content>
