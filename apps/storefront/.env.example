VITE_MEDUSA_BACKEND_URL=http://localhost:9000
VITE_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_key_here

# Supabase (client-side: auth, realtime, etc.)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# For development (storefront runs on this port)
VITE_PORT=5173
VITE_HMR_PORT=24677


VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# Razorpay (Key ID only — safe to expose to client; secret stays on backend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Sentry (client SDK DSN)
VITE_SENTRY_DSN=https://your_sentry_dsn_here
