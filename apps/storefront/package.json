{
  "name": "storefront",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && vite build --config vite.sw.config.ts",
    "start": "node .output/server/index.mjs",
    "serve": "vite preview",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:mobile": "cross-env VITE_CAPACITOR=true vite build --config vite.config.capacitor.ts && node scripts/generate-capacitor-index.mjs",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "cap:run": "cap run android",
    "mobile": "pnpm build:mobile && pnpm cap:sync",
    "import:blog": "npx vite-node scripts/import-blog-posts.tsx"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-app-update": "^8.0.3",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@medusajs/icons": "2.13.4",
    "@medusajs/js-sdk": "2.13.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@sentry/react": "^10.45.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tanstack/react-query": "5.90.20",
    "@tanstack/react-router": "^1.144.0",
    "@tanstack/react-router-ssr-query": "^1.144.0",
    "@tanstack/react-start": "^1.144.0",
    "@tanstack/router-plugin": "^1.144.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "17.2.1",
    "firebase": "^12.11.0",
    "lodash-es": "4.17.21",
    "nitro": "3.0.260311-beta",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-razorpay": "^3.0.1",
    "tailwindcss": "4.1.12",
    "tailwindcss-animate": "^1.0.7",
    "vite-tsconfig-paths": "5.1.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "9.33.0",
    "@medusajs-ai/tags": "next",
    "@medusajs/types": "2.13.4",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-router-devtools": "^1.144.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "4.17.12",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@vitejs/plugin-react": "5.0.1",
    "cross-env": "^10.1.0",
    "eslint": "9.33.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "jsdom": "^29.0.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.39.1",
    "vite": "7.1.2",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-terminal": "1.4.0",
    "vitest": "^4.1.0",
    "workbox-window": "^7.4.0"
  }
}
