# Storefront build-time environment variables
# Copy this to .env.storefront and fill in real values.
# These are injected as Docker build args during `docker compose build` and `scripts/test-deploy.sh`.
# Railway injects them automatically from service variables.

# Medusa backend
VITE_MEDUSA_BACKEND_URL=http://localhost:9000
VITE_MEDUSA_PUBLISHABLE_KEY=
VITE_MEDUSA_PRODUCTION_URL=

# Firebase (push notifications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_VAPID_KEY=

# Payments
VITE_RAZORPAY_KEY_ID=

# Error tracking
VITE_SENTRY_DSN=

# Analytics & tracking
VITE_GSC_VERIFICATION=
VITE_GTM_ID=
VITE_META_PIXEL_ID=

# Supabase (auth/storage)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Site
VITE_SITE_URL=https://suprameds.in
VITE_APP_VERSION=local

# Mobile (Capacitor)
VITE_CAPACITOR=
