{
  "name": "ai-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:dev": "turbo dev --filter=backend",
    "storefront:dev": "turbo dev --filter=storefront",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "docker:build": "docker-compose -f docker-compose.production.yml build",
    "docker:up": "docker-compose -f docker-compose.production.yml up -d",
    "docker:down": "docker-compose -f docker-compose.production.yml down"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.1",
      "react-dom": "19.1.1",
      "@types/react": "19.1.1",
      "@types/react-dom": "19.1.1"
    }
  }
}
